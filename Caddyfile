# AgentID Reverse Proxy Configuration
#
# This Caddyfile configures Caddy as a TLS-terminating reverse proxy
# for the AgentID API server. Caddy automatically provisions and renews
# Let's Encrypt certificates for the specified domain.
#
# Usage with Docker Compose:
#   Mount this file as /etc/caddy/Caddyfile in the Caddy container
#   instead of using the CLI --from/--to flags.
#
# Required: DNS A record pointing the domain to your server IP.

api.agentidapp.com {
    # Proxy all requests to the Node.js backend service
    reverse_proxy backend:3002

    # Security headers for HTTPS hardening
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
    }

    # Access logging with rotation
    log {
        output file /data/access.log {
            roll_size 10mb
            roll_keep 5
        }
    }
}
