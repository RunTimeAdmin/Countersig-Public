PORT=3002
NODE_ENV=development
BAGS_API_KEY=your_bags_api_key
SAID_GATEWAY_URL=https://said-identity-gateway.up.railway.app
DATABASE_URL=postgresql://user:password@localhost:5432/agentid
DB_CA_CERT=                    # Base64-encoded CA certificate for production PostgreSQL SSL
REDIS_URL=redis://localhost:6379
CORS_ORIGIN=https://agentid2.provenanceai.network
BADGE_CACHE_TTL=60
CHALLENGE_EXPIRY_SECONDS=300
AGENTID_BASE_URL=https://agentid2.provenanceai.network
VERIFIED_THRESHOLD=70          # Minimum reputation score for Verified tier badge

# === AgentID 2.0 New Variables ===
# Authentication
JWT_SECRET=your-jwt-secret-change-in-production
ACCESS_TOKEN_SECRET=           # Optional separate secret for access tokens (falls back to JWT_SECRET)
REFRESH_TOKEN_SECRET=          # Optional separate secret for refresh tokens (falls back to JWT_SECRET)
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Email (for org invites)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@agentid.dev

# Organization
DEFAULT_ORG_NAME=Default Organization

# A2A Token Secret (for agent-to-agent authentication tokens)
# DEPRECATED — use A2A_SIGNING_KEY + A2A_VERIFY_KEY instead (HMAC fallback for dev only)
# A2A_TOKEN_SECRET=

# --- A2A Token Ed25519 Keys (REQUIRED in production) ---
# Asymmetric Ed25519 key pair for A2A token signing/verification.
# Generate with:
#   node -e "require('jose').generateKeyPair('EdDSA').then(async({publicKey,privateKey})=>{const j=require('jose');console.log('A2A_SIGNING_KEY='+Buffer.from(await j.exportPKCS8(privateKey)).toString('base64'));console.log('A2A_VERIFY_KEY='+Buffer.from(await j.exportSPKI(publicKey)).toString('base64'))})"
# A2A_SIGNING_KEY=   # Base64-encoded PKCS8 PEM Ed25519 private key
# A2A_VERIFY_KEY=    # Base64-encoded SPKI PEM Ed25519 public key

# API Keys
API_KEY_PREFIX=aid_

# W3C DID Document - Ed25519 public key (multibase encoded) for Solana agent credentials
DID_ED25519_PUBLIC_KEY=
# W3C DID Document - SECP256K1 public key (multibase encoded) for EVM agent credentials
DID_SECP256K1_PUBLIC_KEY=

# ── Enterprise Authentication (OAuth2/OIDC) ──
OAUTH2_ENABLED=false
OAUTH2_ALLOWED_ISSUERS=
OAUTH2_ALLOWED_AUDIENCES=

# ── Microsoft Entra ID ──
ENTRA_ID_ENABLED=false
ENTRA_TENANT_ID=

# ── Operational ──
HEALTH_DETAIL_SECRET=         # Secret for detailed health check endpoint (any strong random string)
COOKIE_DOMAIN=                # Cookie domain scope for cross-subdomain auth (e.g., .agentidapp.com)
DB_POOL_MAX=20                # PostgreSQL connection pool max size
LEGACY_SIGNING_DEADLINE=      # Unix timestamp after which legacy signatures are rejected (default: 2026-07-01)
